{
  "name": "Warden Backend (FastAPI)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/warden-backend",
  "postCreateCommand": "sudo rm -f /etc/apt/sources.list.d/yarn.list && python3 -m venv .venv && .venv/bin/pip install --upgrade pip && .venv/bin/pip install -r requirements.txt",
  "containerEnv": {
    "REDIS_HOST": "redis",
    "REDIS_PORT": "6379",
    "POSTGRES_HOST": "postgres",
    "POSTGRES_PORT": "5432",
    "POSTGRES_DB": "warden",
    "POSTGRES_USER": "postgres",
    "POSTGRES_PASSWORD": "postgres"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python",
        "python.terminal.activateEnvironment": true
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "cweijan.vscode-redis-client"
      ]
    }
  },
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,type=bind,readonly"
  ]
}